# Groq API keys, comma-separated if multiple
API_KEYS="your_groq_api_key_here"

# Output directory
OUTPUT_DIR="./output"

# Generic fallback proxy. Leave empty unless you want all supported requests to use it.
PROXY_URL=""

# Optional per-service proxy.
# Recommended on Tencent Cloud Hong Kong:
# - Groq may need proxy to avoid 403.
# - DeepSeek is often better direct.
YTDLP_PROXY_URL=""
GROQ_PROXY_URL="http://127.0.0.1:7890"
DEEPSEEK_PROXY_URL=""

# DeepSeek summary
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_PROMPT_FILE="prompts/news_analysis.md"
DEEPSEEK_RETRIES=3
DEEPSEEK_TIMEOUT=300

# Optional Bilibili cookies file
BILIBILI_COOKIES="./bilibili.txt"

# Prefer lower bitrate audio first to reduce download size and CDN interruption risk.
YTDLP_AUDIO_FORMAT="30216/30232/30280/ba[ext=m4a]/ba/bestaudio"

# yt-dlp retry/download stability options
YTDLP_RETRIES=30
YTDLP_FRAGMENT_RETRIES=30
YTDLP_FILE_ACCESS_RETRIES=30
YTDLP_RETRY_SLEEP=5
YTDLP_HTTP_CHUNK_SIZE="512K"
